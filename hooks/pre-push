#!/bin/sh

echo "Running pre-push verification tests..."

if [ -d "backend" ] || [ -d "tests" ]; then
  command -v python >/dev/null 2>&1 || {
    echo "Python is required to run backend tests. Push blocked."
    exit 1
  }
  python -m pytest tests/ -q || {
    echo "Backend tests failed. Push blocked."
    exit 1
  }
fi

if [ -f "package.json" ]; then
  command -v npm >/dev/null 2>&1 || {
    echo "npm is required to run frontend tests. Push blocked."
    exit 1
  }
  npm test || {
    echo "Frontend tests failed. Push blocked."
    exit 1
  }
fi

echo "Pre-push checks passed"
